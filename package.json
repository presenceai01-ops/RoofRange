{
  "name": "team-site-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev:client": "vite dev",
    "dev:server": "PORT=3001 bun --watch src/server/index.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "start": "bun run serve.ts",
    "publish": "bash ./publish.sh",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.3",
    "hono": "^4.12.27",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^10.0.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  }
}
